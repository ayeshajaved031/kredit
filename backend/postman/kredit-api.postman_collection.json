            }
          }
        },
        {
          "name": "PUT /admin/startups/:id/credit-limit",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/startups/{{startupId}}/credit-limit",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"approvedCreditLimit\": 5000000,\n  \"adminNotes\": \"Increased after Q3 revenue review\"\n}"
            }
          }
        },
        {
          "name": "POST /admin/financing-requests/:id/approve",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/financing-requests/{{requestId}}/approve",
