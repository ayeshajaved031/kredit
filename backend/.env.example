# ==============================================================
# Kredit Backend — Environment Variables
# Copy to `.env` and fill real values. NEVER commit `.env`.
# ==============================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/kredit?retryWrites=true&w=majority

# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File uploads (vendor invoice PDFs)
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Email (nodemailer) — used for verification, contract notifications,
# payment receipts. For dev, get free SMTP creds from mailtrap.io.
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Kredit <noreply@kredit.pk>"

# Murabaha calculation defaults
# Markup percentage applied to financing requests. Per the iteration
# doc this is the 8–12% "fixed profit" range. Default here is 10%.
MURABAHA_MARKUP_PERCENT=10
MURABAHA_INSTALLMENTS=12

# Default credit limit (PKR) granted to new startups before review
DEFAULT_CREDIT_LIMIT_PKR=2000000

# Payment gateway — 'simulated' for MVP, 'real' for production
PAYMENT_GATEWAY_MODE=simulated
# Simulated success rate (0.0–1.0). 0.95 = 95% of payments succeed.
PAYMENT_GATEWAY_SUCCESS_RATE=0.95

# Repayment cycle scheduler
# Set ENABLE_REPAYMENT_CRON=true to run the daily cycle automatically.
# Cron expression — default 02:00 server time daily. Format: m h dom mon dow
ENABLE_REPAYMENT_CRON=false
REPAYMENT_CRON_SCHEDULE=0 2 * * *
# Days before due date to send a reminder email
REPAYMENT_REMINDER_DAYS_BEFORE=3
# How many consecutive failed installments trigger contract default
DEFAULT_AFTER_FAILED_INSTALLMENTS=3

# Frontend URL — used in email links (verification, password reset)
FRONTEND_URL=http://localhost:5173
